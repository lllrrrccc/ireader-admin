                <input type="text" class="form-input" placeholder="请输入单词">
            </div>
            <div class="form-group">
                <label class="form-label">词性</label>
                <input type="text" class="form-input" placeholder="如：adj. / n. / v.">
            </div>
            <div class="form-group">
                <label class="form-label">释义 <span style="color:var(--danger);">*</span></label>
                <textarea class="form-textarea" rows="3" placeholder="请输入释义"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">单词音频</label>
                <div style="display:flex;gap:8px;align-items:center;">
                    <button class="btn btn-secondary" onclick="document.getElementById('edit-word-audio').click()"><i class="ri-upload-2-line"></i> 上传音频</button>
                    <span style="font-size:12px;color:var(--text-muted);">支持 MP3/WAV 格式</span>
                    <input type="file" id="edit-word-audio" accept="audio/mp3,audio/wav" style="display:none;">
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('modal-edit-word')">取消</button>
            <button class="btn btn-primary">保存</button>
        </div>
    </div>
</div>
`,

