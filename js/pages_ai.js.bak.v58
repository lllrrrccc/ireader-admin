</div>

<!-- 首页推荐 -->
<div id="home-rec-tab">
    <div style="display:flex;gap:16px;height:calc(100vh - 200px);min-height:400px;">
        <!-- 左侧：年级树状结构 -->
        <div class="card" style="width:220px;flex-shrink:0;display:flex;flex-direction:column;overflow:hidden;">
