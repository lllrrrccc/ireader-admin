            <button class="btn btn-primary">保存修改</button>
        </div>
    </div>
</div>

<!-- 查看学生详情模态框 -->
<div class="modal-overlay" id="modal-student-detail">
    <div class="modal" style="max-width:600px;">
        <div class="modal-header">
            <span class="modal-title">学生详情</span>
            <button class="modal-close" onclick="closeModal('modal-student-detail')"><i class="ri-close-line"></i></button>
        </div>
        <div class="modal-body">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;">张</div>
                <div>
                    <h3 style="margin:0 0 4px 0;">张三</h3>
                    <p style="margin:0;color:var(--text-muted);font-size:13px;"><i class="ri-men-line"></i> 男 | 小学三年级</p>
