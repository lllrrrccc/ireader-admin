<!-- 新增设备模态框 -->
<div class="modal-overlay" id="modal-add-device">
    <div class="modal" style="max-width:520px;">
        <div class="modal-header">
            <span class="modal-title">新增设备</span>
            <button class="modal-close" onclick="closeModal('modal-add-device')"><i class="ri-close-line"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">设备编号 <span style="color:var(--danger);">*</span></label>
                <input type="text" class="form-input" placeholder="请输入设备编号">
            </div>
            <div class="form-group">
                <label class="form-label">设备型号 <span style="color:var(--danger);">*</span></label>
                <select class="form-select">
                    <option>iReader Pro</option>
                    <option>iReader Lite</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">系统版本</label>
                <input type="text" class="form-input" placeholder="如 v2.3.1">
            </div>
            <div class="form-group">
                <label class="form-label">绑定学生</label>
                <input type="text" class="form-input" placeholder="搜索学生姓名">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('modal-add-device')">取消</button>
            <button class="btn btn-primary">确认创建</button>
        </div>
    </div>
</div>

<!-- 编辑设备模态框 -->
<div class="modal-overlay" id="modal-edit-device">
    <div class="modal" style="max-width:520px;">
        <div class="modal-header">
            <span class="modal-title">编辑设备</span>
            <button class="modal-close" onclick="closeModal('modal-edit-device')"><i class="ri-close-line"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">设备编号 <span style="color:var(--danger);">*</span></label>
                <input type="text" class="form-input" value="IRP20240001">
            </div>
            <div class="form-group">
                <label class="form-label">设备型号 <span style="color:var(--danger);">*</span></label>
                <select class="form-select">
                    <option selected>iReader Pro</option>
                    <option>iReader Lite</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">系统版本</label>
                <input type="text" class="form-input" value="v2.3.1">
            </div>
            <div class="form-group">
                <label class="form-label">绑定学生</label>
                <input type="text" class="form-input" value="张三">
            </div>
            <div class="form-group">
                <label class="form-label">状态</label>
                <select class="form-select">
                    <option selected>在线</option>
                    <option>离线</option>
                    <option>停用</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('modal-edit-device')">取消</button>
            <button class="btn btn-primary">保存修改</button>
        </div>
    </div>
</div>
`,

